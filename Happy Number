class Solution:
    def isHappy(self, n: int) -> bool:
        num = set()
        while n != 0 and n not in num:
            num.add(n)
            total = 0
            while n > 0:
                digit = n % 10
                total += digit * digit
                n //= 10
            n = total
        return n == 1
                
        
